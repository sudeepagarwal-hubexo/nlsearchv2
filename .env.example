NLSEARCH_DEBUG=true
NLSEARCH_TIMEZONE=Europe/Stockholm
NLSEARCH_REDIS_URL=
NLSEARCH_LICENSED_REGIONS=Stockholm,Göteborg,Skåne,Västra Götaland,Uppsala,Solna,Blekinge,Halland,Småland
NLSEARCH_DATABRICKS_PROFILE=WORKSPACE_EUROPE_DEV
NLSEARCH_DATABRICKS_HOST=
NLSEARCH_DATABRICKS_HTTP_PATH=
# Required for execute=true and for Databricks LLM (primary intent mode)
NLSEARCH_DATABRICKS_TOKEN=
# Or: databricks auth login + NLSEARCH_DATABRICKS_PROFILE
# NLSEARCH_DATABRICKS_AI_GATEWAY_MODEL=databricks-claude-opus-4-8
# NLSEARCH_LLM_PROVIDER=openai
NLSEARCH_LLM_PROVIDER=Anthropic
NLSEARCH_ANTHROPIC_API_KEY=
NLSEARCH_ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
NLSEARCH_OPENAI_MODEL=gpt-4.1-mini
# rules | refine | primary  (primary = Rune LLM intent, then SQL + Databricks)
NLSEARCH_LLM_INTENT_MODE=rules
NLSEARCH_LLM_REFINE_INTENT=true
NLSEARCH_LLM_REFINE_SQL=true
NLSEARCH_LLM_MIN_CONFIDENCE=0.75
NLSEARCH_LLM_FALLBACK_TO_RULES=true

NLSEARCH_UNITY_CATALOG_NAME=gold
NLSEARCH_UNITY_SCHEMA_NAME=hubexo
NLSEARCH_UNITY_TABLE_ALLOWLIST=projects,companies,people,workplaces,project_companies,regions
